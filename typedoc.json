{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs",
  "name": "@saunos/openapi-to-zod",
  "readme": "README.md",
  "includeVersion": true,
  "sourceLinkTemplate": "https://github.com/saunos/openapi-to-zod/blob/{gitRevision}/{path}#L{line}",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "categorizeByGroup": true,
  "groupOrder": ["Functions", "Type Aliases", "Interfaces", "*"],
  "navigationLinks": {
    "GitHub": "https://github.com/saunos/openapi-to-zod",
    "npm": "https://www.npmjs.com/package/@saunos/openapi-to-zod"
  },
  "visibilityFilters": {
    "protected": false,
    "private": false,
    "@internal": false
  },
  "plugin": ["typedoc-material-theme"],
  "themeColor": "#cb9820"
}
