{
  "name": "@saunos/openapi-to-zod",
  "version": "0.4.0",
  "description": "Generate Zod schemas from an OpenAPI spec",
  "license": "MIT",
  "bin": {
    "openapi-to-zod": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:lib": "bun build ./src/index.ts --outdir ./dist --target node --packages external",
    "build:cli": "bun build ./cli.ts --outdir ./dist/bin --target node --packages external && chmod +x ./dist/bin/cli.js",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "bun run build:lib && bun run build:cli && bun run build:types",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "prepublishOnly": "bun run tsc && bun run lint && bun run fmt && bun run test && bun run build",
    "tsc": "bunx tsc --noEmit",
    "test": "bun test --coverage",
    "lint": "oxlint src",
    "fmt:write": "oxfmt src",
    "fmt": "oxfmt --check src"
  },
  "dependencies": {
    "@scalar/openapi-types": "^0.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typedoc": "^0.28.17",
    "typedoc-material-theme": "^1.4.1",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "typescript": "^5",
    "zod": "^4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "zod": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=18"
  }
}
